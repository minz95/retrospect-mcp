{
  "name": "@minz95/retrospect-mcp",
  "version": "1.0.0",
  "description": "MCP server for daily dev logs, insights extraction, and SNS publishing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "retrospect-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "config",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "mcp",
    "retrospect",
    "dev-logs",
    "insights",
    "obsidian",
    "notion"
  ],
  "author": "minz95",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minz95/retrospect-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/minz95/retrospect-mcp/issues"
  },
  "homepage": "https://github.com/minz95/retrospect-mcp#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@notionhq/client": "^2.2.15",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "gitlog": "^4.0.8",
    "mustache": "^4.2.0",
    "twitter-api-v2": "^1.17.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.12",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
